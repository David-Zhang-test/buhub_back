{
  "name": "buhub-back",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node server.js --dev",
    "build": "next build",
    "start": "node server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:backfill:mentions": "node scripts/backfill-mention-notifications.js",
    "rating:template": "node scripts/generate-rating-import-template.mjs",
    "rating:import": "node scripts/import-rating-bundle.mjs",
    "perf:k6:local": "k6 run perf/k6-local-api.js",
    "perf:k6:local:light": "LOAD_TIER=light k6 run perf/k6-local-api.js",
    "perf:k6:local:medium": "LOAD_TIER=medium k6 run perf/k6-local-api.js",
    "perf:k6:local:heavy": "LOAD_TIER=heavy k6 run perf/k6-local-api.js",
    "perf:autocannon:local": "node perf/autocannon-local-api.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@prisma/client": "^5.22.0",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "ioredis": "^5.4.1",
    "isomorphic-dompurify": "^3.0.0",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.2",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autocannon": "^8.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2",
    "xlsx": "^0.18.5"
  }
}
