# =============================================================================
# BUHUB Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Run `docker compose up -d` to start PostgreSQL and Redis.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Docker)
# -----------------------------------------------------------------------------
# Default credentials match docker-compose.yml
# Port 5434: docker-compose.yml maps 5432 to avoid conflict with system Postgres
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://buhub:buhub@localhost:5432/buhub"

# Optional: AWS RDS for one-off restore (scripts/db-restore-to-aws.sh). Use sslmode=require.
# DATABASE_URL_AWS="postgresql://USER:PASSWORD@your-db.xxxx.ap-southeast-1.rds.amazonaws.com:5432/buhub?sslmode=require"

# -----------------------------------------------------------------------------
# Redis (via Docker)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET="change-this-to-a-secure-random-string-min-32-chars"
JWT_EXPIRY="7d"

# -----------------------------------------------------------------------------
# Email (verification codes, password reset) — Resend API only
# -----------------------------------------------------------------------------
# RESEND_API_KEY=re_xxxxxxxxxxxx
# Required: sender address (must match a verified domain in Resend)
EMAIL_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# hCaptcha (send-code verification)
# Get keys at https://dashboard.hcaptcha.com/
# -----------------------------------------------------------------------------
HCAPTCHA_SECRET_KEY=your_secret_key

# -----------------------------------------------------------------------------
# App URL (required for email links, presigned uploads)
# -----------------------------------------------------------------------------
# Base URL of the app/API, e.g. https://www.uhub.help (no trailing slash)
NEXT_PUBLIC_APP_URL=https://www.uhub.help

# -----------------------------------------------------------------------------
# Content Moderation (OpenAI Moderation API - free)
# Get key at https://platform.openai.com/api-keys
# Supports both text and image moderation (omni-moderation-latest)
# If unset, moderation is disabled (fail-open).
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Next.js Server Actions (optional, for stable builds across deploys)
# Set at BUILD time to avoid "Failed to find Server Action" after new deploy.
# Generate: openssl rand -base64 32
# -----------------------------------------------------------------------------
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=your-base64-32-bytes

# -----------------------------------------------------------------------------
# Logging (optional)
# -----------------------------------------------------------------------------
# LOG_LEVEL=error|warn|info|debug (default: production=info, dev=debug)
# LOG_DIR= 目录路径则写入按日轮转文件：app-YYYY-MM-DD.log、error-YYYY-MM-DD.log
# 开发环境勿把 LOG_DIR 放在项目目录内（会触发 Next 反复编译）；可留空仅 stdout，或设到 /tmp/buhub-logs 等
# 生产 Docker 已挂载 /app/logs，设置 LOG_DIR=/app/logs 即可落盘
# LOG_LEVEL=info
# LOG_DIR=/app/logs

# -----------------------------------------------------------------------------
# S3 uploads (optional — private bucket OK)
# -----------------------------------------------------------------------------
# S3_UPLOADS_BUCKET=your-bucket
# AWS_REGION=ap-southeast-1
# Prefix for **new** objects (no leading/trailing slash). Empty → writes use `public/uploads/<key>` (same as migrate script).
# Override base path:
# S3_UPLOADS_KEY_PREFIX=my/custom/prefix
# Legacy buckets that store only `userId/file.jpg` at bucket root for new PUTs:
# S3_UPLOADS_BARE_ROOT=1
# Reads always try: PREFIX/key, public/uploads/key, public/uploads/public/uploads/key, uploads/key, key.
# AWS_ACCESS_KEY_ID=   (omit on AWS if using instance role)
# AWS_SECRET_ACCESS_KEY=
#
# API base URL (same host the app calls for /api). Used to build file URLs like:
#   https://YOUR_DOMAIN/api/uploads/avatars/...
# Client loads files through your server, which reads objects from S3 (needs s3:GetObject).
# NEXT_PUBLIC_APP_URL=https://api.yourdomain.com
#
# Optional later — direct/CDN URL prefix (no trailing slash). If set, stored URLs point here instead.
# ASSET_PUBLIC_BASE_URL=https://cdn.yourdomain.com
#
# S3_DEBUG_UPLOADS=1   # log each S3 HEAD failure (NotFound vs AccessDenied vs region)
#
# Presigned PUT from the mobile app: S3 bucket CORS must allow PUT from your origins.
# Migration: npm run migrate:uploads-to-s3 -- --dry-run
# UPLOADS_SOURCE_DIR=/path/to/uploads   (optional)

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# CRON_SECRET=secret-for-cron-endpoints
# DEBUG_PRISMA=1
