# =============================================================================
# BUHUB Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Run `docker compose up -d` to start PostgreSQL and Redis.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Docker)
# -----------------------------------------------------------------------------
# Default credentials match docker-compose.yml
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://buhub:buhub@localhost:5432/buhub"

# -----------------------------------------------------------------------------
# Redis (via Docker)
# -----------------------------------------------------------------------------
# No password by default. Add ?password=xxx for Redis 6+ ACL if needed.
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET="change-this-to-a-secure-random-string-min-32-chars"
JWT_EXPIRY="7d"

# -----------------------------------------------------------------------------
# Email (for verification codes, password reset)
# Choose ONE: SMTP or Resend
# -----------------------------------------------------------------------------
# Option A: SMTP (Gmail, SendGrid, Mailgun, 阿里云邮件推送, etc.)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password

# Option B: Resend API (https://resend.com - simple, free tier)
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Required for both: sender address
# EMAIL_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# hCaptcha (for send-code verification)
# Get keys at https://dashboard.hcaptcha.com/
# -----------------------------------------------------------------------------
# HCAPTCHA_SECRET_KEY=your_secret_key

# -----------------------------------------------------------------------------
# OSS / File Storage (Alibaba Cloud OSS / AWS S3)
# -----------------------------------------------------------------------------
# OSS_REGION=
# OSS_BUCKET=
# OSS_ACCESS_KEY=
# OSS_SECRET_KEY=

# -----------------------------------------------------------------------------
# Optional: Vector Search (Pinecone/Qdrant/Weaviate)
# -----------------------------------------------------------------------------
# PINECONE_API_KEY=
# PINECONE_INDEX=

# -----------------------------------------------------------------------------
# Optional: Push Notifications
# -----------------------------------------------------------------------------
# FCM_SERVER_KEY=
# JPUSH_APP_KEY=
# JPUSH_MASTER_SECRET=
