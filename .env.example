# =============================================================================
# BUHUB Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Run `docker compose up -d` to start PostgreSQL and Redis.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Docker)
# -----------------------------------------------------------------------------
# Default credentials match docker-compose.yml
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://buhub:buhub@localhost:5432/buhub"

# -----------------------------------------------------------------------------
# Redis (via Docker)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET="change-this-to-a-secure-random-string-min-32-chars"
JWT_EXPIRY="7d"

# -----------------------------------------------------------------------------
# Email (verification codes, password reset)
# Choose ONE: SMTP or Resend
# -----------------------------------------------------------------------------
# Option A: SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password

# Option B: Resend API (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Required: sender address
EMAIL_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# hCaptcha (send-code verification)
# Get keys at https://dashboard.hcaptcha.com/
# -----------------------------------------------------------------------------
HCAPTCHA_SECRET_KEY=your_secret_key

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# CRON_SECRET=secret-for-cron-endpoints
# DEBUG_PRISMA=1
