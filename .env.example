# =============================================================================
# BUHUB Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Run `docker compose up -d` to start PostgreSQL and Redis.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Docker)
# -----------------------------------------------------------------------------
# Default credentials match docker-compose.yml
# Port 5434: docker-compose.yml maps 5432 to avoid conflict with system Postgres
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://buhub:buhub@localhost:5432/buhub"

# -----------------------------------------------------------------------------
# Redis (via Docker)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET="change-this-to-a-secure-random-string-min-32-chars"
JWT_EXPIRY="7d"

# -----------------------------------------------------------------------------
# Email (verification codes, password reset) — Resend API only
# -----------------------------------------------------------------------------
# RESEND_API_KEY=re_xxxxxxxxxxxx
# Required: sender address (must match a verified domain in Resend)
EMAIL_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# hCaptcha (send-code verification)
# Get keys at https://dashboard.hcaptcha.com/
# -----------------------------------------------------------------------------
HCAPTCHA_SECRET_KEY=your_secret_key

# -----------------------------------------------------------------------------
# App URL (required for email links, presigned uploads)
# -----------------------------------------------------------------------------
# Base URL of the app/API, e.g. https://www.uhub.help (no trailing slash)
NEXT_PUBLIC_APP_URL=https://www.uhub.help

# -----------------------------------------------------------------------------
# Content Moderation (OpenAI Moderation API - free)
# Get key at https://platform.openai.com/api-keys
# Supports both text and image moderation (omni-moderation-latest)
# If unset, moderation is disabled (fail-open).
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Next.js Server Actions (optional, for stable builds across deploys)
# Set at BUILD time to avoid "Failed to find Server Action" after new deploy.
# Generate: openssl rand -base64 32
# -----------------------------------------------------------------------------
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=your-base64-32-bytes

# -----------------------------------------------------------------------------
# Logging (optional)
# -----------------------------------------------------------------------------
# LOG_LEVEL=error|warn|info|debug (default: production=info, dev=debug)
# LOG_DIR= 目录路径则写入按日轮转文件：app-YYYY-MM-DD.log、error-YYYY-MM-DD.log
# 生产 Docker 已挂载 /app/logs，设置 LOG_DIR=/app/logs 即可落盘
# LOG_LEVEL=info
# LOG_DIR=/app/logs

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# CRON_SECRET=secret-for-cron-endpoints
# DEBUG_PRISMA=1
