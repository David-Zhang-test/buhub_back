// BUHUB Backend - Prisma Schema
// Single Source of Truth: AGENT_IMPLEMENTATION_GUIDE.md

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum Role {
  USER
  ADMIN
  MODERATOR
}

enum PartnerCategory {
  TRAVEL
  FOOD
  COURSE
  SPORTS
  OTHER
}

enum ErrandCategory {
  PICKUP
  BUY
  OTHER
}

enum SecondhandCategory {
  ELECTRONICS
  BOOKS
  FURNITURE
  OTHER
}

enum RatingCategory {
  COURSE
  TEACHER
  CANTEEN
  MAJOR
}

enum FeedbackCategory {
  BUG
  SUGGESTION
  OTHER
}

enum FeedbackStatus {
  UNRESOLVED
  RESOLVED
  CLOSED
}

enum ProfileVisibility {
  PUBLIC
  MUTUAL
  HIDDEN
}

enum LockerRequestStatus {
  DROP_OFF_PROCESSING
  DROP_OFF_COMPLETE
  PICK_UP_PROCESSING
  PICK_UP_COMPLETE
}

// =============================================================================
// User System (Module 1)
// =============================================================================

model User {
  // Identity & auth
  id           String  @id @default(uuid())
  userName     String? @unique // Unique handle for /user/:userName lookup
  passwordHash String? // Email/password auth (optional for email-verify flow)

  // Profile
  name     String?
  nickname String
  avatar   String
  bio      String  @default("")
  grade    String?
  major    String?
  gender   String  @default("other") // 'male', 'female', 'other'

  // App & account status
  role               Role              @default(USER)
  language           String            @default("en")
  isActive           Boolean           @default(true)
  isBanned           Boolean           @default(false)
  profileVisibility  ProfileVisibility @default(PUBLIC)

  // Legal & activity
  agreedToTerms   Boolean   @default(false)
  agreedToTermsAt DateTime?
  lastLoginAt     DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations — identity & auth
  accounts           Account[]
  emails             UserEmail[]
  verificationTokens VerificationToken[]

  // Relations — content & engagement
  posts            Post[]
  comments         Comment[]
  likes            Like[]
  reports          Report[]
  bookmarks        Bookmark[]
  commentBookmarks CommentBookmark[]
  ratings          Rating[]

  // Relations — social graph
  blockedUsers Block[]  @relation("BlockedBy")
  blockedBy    Block[]  @relation("BlockedUser")
  following    Follow[] @relation("Follower")
  followers    Follow[] @relation("Following")

  // Relations — notifications & messaging
  notifications        Notification[]
  notificationsSent    Notification[]       @relation("NotificationActor")
  sentMessages         DirectMessage[]      @relation("MessageSender")
  receivedMessages     DirectMessage[]      @relation("MessageReceiver")
  ownedConversations   DirectConversation[] @relation("ConversationOwner")
  partnerConversations DirectConversation[] @relation("ConversationPartner")

  // Relations — marketplace / partner / errands / secondhand
  partnerPosts    PartnerPost[]
  partnerJoins    PartnerJoin[]
  errands         Errand[]
  errandAccepts   ErrandAccept[]
  secondhandItems SecondhandItem[]
  secondhandWants SecondhandWant[]

  // Relations — device & preferences
  pushTokens             PushToken[]
  notificationPreference NotificationPreference?
  schedule               Schedule?

  // Relations — invites & admin
  ownedInviteCodes InviteCode[]    @relation("InviteCodeOwner")
  usedInviteCodes  InviteCode[]    @relation("InviteCodeUsedBy")
  feedbacks        Feedback[]
  feedbackReplies  FeedbackReply[] @relation("FeedbackReplyUser")
  lockerRequests   LockerRequest[] @relation("LockerRequestUser")

  @@index([role])
  @@index([nickname])
  @@index([userName])
}

model UserEmail {
  id         String    @id @default(uuid())
  userId     String
  email      String    @unique
  type       String
  canLogin   Boolean   @default(true)
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model InviteCode {
  id           String    @id @default(uuid())
  code         String    @unique
  ownerUserId  String
  usedByUserId String?
  usedAt       DateTime?
  createdAt    DateTime  @default(now())

  ownerUser  User  @relation("InviteCodeOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  usedByUser User? @relation("InviteCodeUsedBy", fields: [usedByUserId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@index([usedByUserId])
  @@index([createdAt])
}

// OAuth / third-party identities only. Email login uses UserEmail — do not create provider=email rows for new users.
model Account {
  id                String   @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model VerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  type      String // 'email_verification', 'password_reset'
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("BlockedBy", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model DirectMessage {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String   @db.Text
  images     String[]
  isRead     Boolean  @default(false)
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId, senderId])
  @@index([createdAt])
  @@index([receiverId, isRead, isDeleted])
  @@index([senderId, receiverId, isDeleted, createdAt])
}

model DirectConversation {
  id               String    @id @default(uuid())
  ownerId          String
  partnerId        String
  lastInteractedAt DateTime  @default(now())
  clearedAt        DateTime?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  owner   User @relation("ConversationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  partner User @relation("ConversationPartner", fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, partnerId])
  @@index([ownerId, lastInteractedAt])
  @@index([ownerId, deletedAt, lastInteractedAt])
  @@index([partnerId])
}

model ContentTranslation {
  id             String   @id @default(uuid())
  entityType     String
  entityId       String
  fieldName      String
  sourceLanguage String
  targetLanguage String
  sourceHash     String
  translatedText String   @db.Text
  status         String   @default("completed")
  model          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([entityType, entityId, fieldName, targetLanguage])
  @@index([entityType, entityId])
  @@index([targetLanguage])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// =============================================================================
// Forum System (Module 2)
// =============================================================================

model Post {
  id              String   @id @default(uuid())
  authorId        String
  postType        String   @default("image-text")
  sourceLanguage  String   @default("tc")
  content         String   @db.Text
  images          String[]
  anonymousName   String?
  anonymousAvatar String?
  viewCount       Int      @default(0)
  likeCount       Int      @default(0)
  commentCount    Int      @default(0)
  tags            String[]
  category        String?
  isAnonymous     Boolean  @default(false)
  isRepost        Boolean  @default(false)
  originalPostId  String?
  isDeleted       Boolean  @default(false)

  // Poll-specific
  pollOptions PollOption[] @relation("PostPollOptions")
  pollEndDate DateTime?
  votes       Vote[]       @relation("PostVotes")

  // Category-specific
  partnerType  String?
  eventEndDate DateTime?
  price        Float?
  errandType   String?
  startAddress String?
  endAddress   String?
  taskEndTime  DateTime?
  itemPrice    Float?
  itemLocation String?
  saleEndTime  DateTime?
  itemStatus   String?   @default("available")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author       User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments     Comment[]
  likes        Like[]
  bookmarks    Bookmark[]
  reports      Report[]
  originalPost Post?      @relation("PostRepost", fields: [originalPostId], references: [id], onDelete: Cascade)
  reposts      Post[]     @relation("PostRepost")

  @@index([authorId])
  @@index([createdAt])
  @@index([category])
  @@index([postType])
  @@index([isDeleted, createdAt(sort: Desc)])
  @@index([isDeleted, category, createdAt(sort: Desc)])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  postId    String?
  commentId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([userId])
  @@index([postId])
  @@index([commentId])
}

model Comment {
  id              String   @id @default(uuid())
  postId          String
  authorId        String
  sourceLanguage  String   @default("tc")
  content         String   @db.Text
  parentId        String?
  likeCount       Int      @default(0)
  isAnonymous     Boolean  @default(false)
  anonymousName   String?
  anonymousAvatar String?
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  post             Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  author           User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent           Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies          Comment[]         @relation("CommentReplies")
  likes            Like[]
  bookmarks        Bookmark[]
  commentBookmarks CommentBookmark[]
  reports          Report[]

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@index([postId, isDeleted, parentId, createdAt])
}

model CommentBookmark {
  id        String   @id @default(uuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([userId])
  @@index([commentId])
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  postId    String?
  commentId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postId])
  @@index([commentId])
}

model Tag {
  id         String   @id @default(uuid())
  name       String   @unique
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([name])
}

model Report {
  id         String   @id @default(uuid())
  reporterId String
  postId     String?
  commentId  String?
  reason     String
  snapshot   Json
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  reporter User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  post     Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  comment  Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)

  @@index([reporterId])
  @@index([postId])
  @@index([commentId])
  @@index([status])
}

model PollOption {
  id        String   @id @default(uuid())
  postId    String
  text      String
  voteCount Int      @default(0)
  createdAt DateTime @default(now())

  post  Post   @relation("PostPollOptions", fields: [postId], references: [id], onDelete: Cascade)
  votes Vote[]

  @@index([postId])
}

model Vote {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  optionId  String
  createdAt DateTime @default(now())

  post   Post       @relation("PostVotes", fields: [postId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([optionId])
}

// =============================================================================
// Additional Features (Module 3)
// =============================================================================

model PartnerPost {
  id             String          @id @default(uuid())
  category       PartnerCategory
  type           String
  sourceLanguage String          @default("tc")
  title          String
  description    String          @db.Text
  time           String
  location       String
  authorId       String
  expired        Boolean         @default(false)
  expiresAt      DateTime
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  author User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  joins  PartnerJoin[]

  @@index([category])
  @@index([expired])
  @@index([createdAt])
}

model PartnerJoin {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post PartnerPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model Errand {
  id             String         @id @default(uuid())
  category       ErrandCategory
  type           String
  sourceLanguage String         @default("tc")
  title          String
  description    String         @db.Text
  from           String
  to             String
  price          String
  item           String
  time           String
  authorId       String
  expired        Boolean        @default(false)
  expiresAt      DateTime
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  author  User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  accepts ErrandAccept[]

  @@index([category])
  @@index([expired])
  @@index([createdAt])
}

model ErrandAccept {
  id        String   @id @default(uuid())
  errandId  String
  userId    String
  createdAt DateTime @default(now())

  errand Errand @relation(fields: [errandId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([errandId, userId])
  @@index([errandId])
  @@index([userId])
}

model SecondhandItem {
  id             String             @id @default(uuid())
  category       SecondhandCategory
  type           String
  sourceLanguage String             @default("tc")
  title          String
  description    String             @db.Text
  price          String
  condition      String
  location       String
  images         String[]
  authorId       String
  sold           Boolean            @default(false)
  expired        Boolean            @default(false)
  expiresAt      DateTime
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  author User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  wants  SecondhandWant[]

  @@index([category])
  @@index([sold])
  @@index([expired])
  @@index([createdAt])
}

model SecondhandWant {
  id        String   @id @default(uuid())
  itemId    String
  userId    String
  createdAt DateTime @default(now())

  item SecondhandItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId])
  @@index([itemId])
  @@index([userId])
}

model RatingItem {
  id         String         @id @default(uuid())
  category   RatingCategory
  name       String
  department String
  code       String?
  email      String?
  location   String?
  avatar     String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  ratings Rating[]

  @@unique([category, code])
  @@index([category])
  @@index([name])
}

model Rating {
  id        String   @id @default(uuid())
  itemId    String
  userId    String
  scores    Json
  tags      String[]
  comment   String?  @db.Text
  semester  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item RatingItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId, semester])
  @@index([itemId])
  @@index([userId])
  @@index([createdAt])
}

model ScoreDimension {
  id       String         @id @default(uuid())
  category RatingCategory
  name     String
  label    Json
  order    Int

  @@unique([category, name])
  @@index([category])
}

// =============================================================================
// Notifications (Module 4)
// =============================================================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  actorId   String?
  postId    String?
  commentId String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([type])
  @@index([createdAt])
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String // 'ios', 'android', 'web'
  provider  String // 'expo' | 'fcm' | 'jpush'
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NotificationPreference {
  id        String   @id @default(uuid())
  userId    String   @unique
  likes     Boolean  @default(true)
  comments  Boolean  @default(true)
  followers Boolean  @default(true)
  messages  Boolean  @default(true)
  system    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// =============================================================================
// Analytics (Module 6)
// =============================================================================

model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String?
  eventType String
  eventData Json
  timestamp DateTime @default(now())

  @@index([eventType, timestamp])
  @@index([userId])
}

// =============================================================================
// AI Schedule (Module 7)
// =============================================================================

model Schedule {
  id        String   @id @default(cuid())
  userId    String   @unique
  imageUrl  String?
  courses   Course[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id         String @id @default(cuid())
  scheduleId String
  name       String
  location   String @default("")
  dayOfWeek  Int
  startTime  String
  endTime    String
  color      String @default("#FFF6D7")

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
}

// =============================================================================
// Feedback System (Module 8)
// =============================================================================

model Feedback {
  id          String           @id @default(uuid())
  userId      String
  category    FeedbackCategory
  description String           @db.Text
  imageUrls   String[]
  status      FeedbackStatus   @default(UNRESOLVED)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies FeedbackReply[]

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model FeedbackReply {
  id         String   @id @default(uuid())
  feedbackId String
  userId     String
  isAdmin    Boolean  @default(false)
  content    String   @db.Text
  createdAt  DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user     User     @relation("FeedbackReplyUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([feedbackId])
  @@index([userId])
}

model LockerRequest {
  id               String              @id @default(uuid())
  userId           String              @unique
  fullName         String
  studentId        String
  phoneNumber      String
  residenceAddress String              @db.Text
  dropOffDate      DateTime            @db.Date
  status           LockerRequestStatus @default(DROP_OFF_PROCESSING)
  modifyCount      Int                 @default(0)
  boxCount         Int                 @default(1)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user User @relation("LockerRequestUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
}

// Single-row broadcast shown on the locker screen once the info-collection
// deadline passes. Admin edits via the admin SPA; mobile polls every 30s.
// Row id is always the string "global".
model LockerBroadcast {
  id                   String   @id
  message              String   @db.Text
  featureEnabled       Boolean  @default(true)
  openAt               DateTime?
  closeAt              DateTime?
  announcementStartAt  DateTime?
  announcementEndAt    DateTime?
  isPublished          Boolean  @default(false)
  updatedAt            DateTime @updatedAt
}

// Single-row global announcement shown when users open the app.
// Row id is always "global". Admin can optionally fan out a push.
model GlobalAnnouncement {
  id             String    @id
  title          String
  content        String    @db.Text
  imageUrl       String?
  pushBody       String?
  displayStartAt DateTime?
  displayEndAt   DateTime?
  isPublished    Boolean   @default(false)
  updatedAt      DateTime  @updatedAt
  publishedAt    DateTime?
}
